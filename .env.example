# --- AURA (AUR) L2 ENVIRONMENT TEMPLATE ---
# (Copy this to .env and fill in your secrets)

# --- SUPABASE CONFIG ---
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_BE_CAREFUL
SUPABASE_ANON_KEY=your_anon_public_key

# --- AURA POOL ASSETS ---
# Generated via generate_pool_keys.mjs
AURA_POOL_ADDRESS=your_pool_address
AURA_POOL_PUBLIC_KEY=your_pool_public_key
AURA_POOL_PRIVATE_KEY=your_pool_private_key_SECRET

# --- DEV TOOLS ---
# Used by scripts for testing
FROM_ADDRESS=
FROM_PRIV_HEX=
TO_ADDRESS=
AMOUNT_ATOM=
FROM_NONCE=0
PREV_EVENT_HASH=
