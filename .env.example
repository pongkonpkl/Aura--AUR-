# --- AURA (AUR) SOVEREIGN STACK — ENVIRONMENT TEMPLATE ---
# Copy this file to .env and fill in your values
# NEVER commit your real .env to GitHub!

# ============================================================
# SECTION 1: SUPABASE (Frontend + Backend)
# ============================================================
# Get from: https://app.supabase.com -> Project Settings -> API

# Used by the FRONTEND (Vite — must prefix with VITE_)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Used by the GUARDIAN NODE BACKEND (Server-side only)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_SECRET_NEVER_SHARE

# ============================================================
# SECTION 2: BLOCKCHAIN (Guardian Node / Distributor Bot)
# ============================================================
# RPC URL: Get from Alchemy / Infura / QuickNode
RPC_URL=https://mainnet.infura.io/v3/your_api_key
SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/your_key

# Master distributor wallet — This wallet pays gas and signs txns
# KEEP THIS ABSOLUTELY SECRET — TREAT LIKE A BANK PASSWORD
DISTRIBUTOR_PRIVATE_KEY=0xyour_private_key_never_share
PRIVATE_KEY=0xyour_deployer_private_key_never_share
GUARDIAN_PRIVATE_KEY=0xyour_guardian_private_key_never_share

# Contract addresses for backend bots
REWARD_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000
ETERNITY_POOL_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================================
# SECTION 3: AURA POOL IDENTITY (Optional — for advanced setup)
# ============================================================
AURA_POOL_ADDRESS=your_pool_contract_address
AURA_POOL_PUBLIC_KEY=your_pool_public_key
